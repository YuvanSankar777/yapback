GEMINI_API_KEY=your_google_ai_studio_key_here
ENDEE_URL=http://localhost:8080
COLLECTION=videomind

# --- Optional: proxy for reaching YouTube from a cloud host ---------------
# Cloud IPs (Hugging Face, most VMs) are blocked by YouTube, so a RESIDENTIAL
# proxy is required to ingest videos there. Set ONE of the following.
#
# Option A — Webshare residential (https://www.webshare.io, "Residential" plan):
# WEBSHARE_PROXY_USERNAME=your_webshare_username
# WEBSHARE_PROXY_PASSWORD=your_webshare_password
#
# Option B — any generic http(s) proxy (or your own self-hosted one):
# PROXY_URL=http://user:pass@host:port
